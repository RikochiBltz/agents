# ── Backend ──────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8081

# ── Data Agent LLM (DeepSeek cloud via Ollama) ───────────────────────
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=deepseek-v3:latest

# ── Orchestrator LLM (gpt-oss:20b cloud via Ollama) ──────────────────
ORCHESTRATOR_BASE_URL=http://localhost:11434/v1
ORCHESTRATOR_API_KEY=ollama
ORCHESTRATOR_MODEL=gpt-oss:20b

# ── Auth (leave blank while auth is disabled on the backend) ─────────
BACKEND_EMAIL=
BACKEND_PASSWORD=

# ── RAG ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=nomic-embed-text
PDF_PATH=vital_dictionnaire_donnees_complet.pdf
